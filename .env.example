# Database
DATABASE_PATH=data/cnpj.db

# Auth — set at least one secret for production.
# If none are set the API runs without auth (development mode).
RAPIDAPI_PROXY_SECRET=
APILAYER_PROXY_SECRET=
ZYLA_PROXY_SECRET=
MASTER_API_KEY=change-me-to-a-random-secret

# Scheduler
IMPORT_INTERVAL_HOURS=24

# Receita Federal source URL template ({batch} is replaced by YYYY-MM)
RECEITA_BASE_URL=https://arquivos.receitafederal.gov.br/index.php/s/YggdBLfdninEJX9?dir=/{batch}
