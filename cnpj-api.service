[Unit]
Description=CNPJ API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/cnpj-api
Environment=PATH=/root/cnpj-api/.venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/root/cnpj-api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
